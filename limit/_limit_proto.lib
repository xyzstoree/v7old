#!/bin/bash
# Common library untuk limit/{vmess,vless,trojan,shadowsocks}
# Tidak dijalankan langsung; di-source oleh script per-protokol.

send-log() {
    CHATID=$(grep -E "^#bot# " "/etc/bot/.bot.db" 2>/dev/null | cut -d ' ' -f 3)
    KEY=$(grep -E "^#bot# " "/etc/bot/.bot.db" 2>/dev/null | cut -d ' ' -f 2)
    [ -z "$CHATID" ] || [ -z "$KEY" ] && return 0
    local TIME="10"
    local URL="https://api.telegram.org/bot$KEY/sendMessage"
    local TEXT="
<code>в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ</code>
<b>вљ пёЏNOTIF QUOTA HABISвљ пёЏ</b>
<code>в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ</code>
<code>Username  : </code><code>$user</code>
<code>Usage     : </code><code>$total</code>
<code>в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ</code>
"
    curl -s --max-time $TIME -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" "$URL" >/dev/null
}

con() {
    local -i bytes=$1
    if   [[ $bytes -lt 1024 ]];        then echo "${bytes}B"
    elif [[ $bytes -lt 1048576 ]];     then echo "$(( (bytes + 1023)/1024 ))KB"
    elif [[ $bytes -lt 1073741824 ]];  then echo "$(( (bytes + 1048575)/1048576 ))MB"
    else echo "$(( (bytes + 1073741823)/1073741824 ))GB"
    fi
}

# Akumulasi statistik dari xray api ke /etc/limit/<proto>/<user>
accumulate_stats() {
    local prefix="$1" dir="$2"
    local data
    data=( $(grep "^${prefix}" /etc/xray/config.json | cut -d ' ' -f 2 | sort -u) )
    mkdir -p "/etc/limit/${dir}"
    for user in "${data[@]}"; do
        local raw inb outb quota0 quota1
        raw=$(xray api statsquery --server=127.0.0.1:10000 \
            | grep -C 2 "$user" | sed -e '/^}$/d' -e '/^{$/d' \
            | grep value | awk '{print $2}' | sed 's/[",]//g' | sort)
        inb=$(echo "$raw"  | sed -n 1p)
        outb=$(echo "$raw" | sed -n 2p)
        quota0=$(( ${inb:-0} + ${outb:-0} ))
        if [ -e "/etc/limit/${dir}/${user}" ]; then
            quota1=$(cat "/etc/limit/${dir}/${user}")
            if [[ ${#quota1} -gt 0 ]]; then
                echo "$(( quota0 + quota1 ))" > "/etc/limit/${dir}/${user}"
            else
                echo "$quota0" > "/etc/limit/${dir}/${user}"
            fi
        else
            echo "$quota0" > "/etc/limit/${dir}/${user}"
        fi
        xray api stats --server=127.0.0.1:10000 -name "user>>>${user}>>>traffic>>>downlink" -reset > /dev/null 2>&1
    done
}

# Loop utama: cek user yang sudah lampaui kuota lalu hapus.
# FIX #5/#37: cuma restart xray sekali per iterasi (kalau ada user dihapus).
run_protocol_loop() {
    local prefix="$1" dir="$2" db="$3"
    while true; do
        sleep 60
        accumulate_stats "$prefix" "$dir"

        local data dirty=0
        data=( $(grep "^${prefix}" /etc/xray/config.json | cut -d ' ' -f 2 | sort -u) )
        for user in "${data[@]}"; do
            [ -e "/etc/${dir}/${user}" ] || continue
            local cekdulu pakai
            cekdulu=$(cat "/etc/${dir}/${user}")
            [[ ${#cekdulu} -gt 1 ]] || continue
            [ -e "/etc/limit/${dir}/${user}" ] || continue
            pakai=$(cat "/etc/limit/${dir}/${user}")
            if [[ ${pakai} -gt ${cekdulu} ]]; then
                local exp
                exp=$(grep -w "^${prefix} $user" "/etc/xray/config.json" | cut -d ' ' -f 3 | sort -u)
                sed -i "/^${prefix} $user $exp/,/^},{/d" /etc/xray/config.json
                sed -i "/^### $user $exp/d" "$db"
                bol=$(cat "/etc/limit/${dir}/${user}")
                total=$(con "$bol")
                send-log
                rm -f "/etc/limit/${dir}/${user}"
                dirty=1
            fi
        done
        if [[ $dirty -eq 1 ]]; then
            systemctl restart xray >/dev/null 2>&1
        fi
    done
}
