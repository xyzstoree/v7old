#!/bin/bash
# limit/shadowsocks — daemon kuota shadowsocks
# FIX #5/#37: restart xray hanya ketika ada user expired, sleep 60s
LIB="$(dirname "$(readlink -f "$0")")/_limit_proto.lib"
[ -f "$LIB" ] && . "$LIB" || . /etc/xray/_limit_proto.lib

# Shadowsocks pakai prefix "#!#" dan reads dari /etc/shadowsocks/.shadowsocks.db
while true; do
    sleep 60
    data=( $(grep '^#!#' /etc/shadowsocks/.shadowsocks.db | cut -d ' ' -f 2 | sort -u) )
    mkdir -p /etc/limit/shadowsocks

    for user in "${data[@]}"; do
        xray api stats --server=127.0.0.1:10000 -name "user>>>${user}>>>traffic>>>downlink" >& "/tmp/${user}"
        getThis=$(awk '{print $1}' "/tmp/${user}")
        [[ "$getThis" == "failed" ]] && continue
        downlink=$(xray api stats --server=127.0.0.1:10000 -name "user>>>${user}>>>traffic>>>downlink" \
            | grep -w value | awk '{print $2}' | tr -d '"')
        if [ -e "/etc/limit/shadowsocks/${user}" ]; then
            plus2=$(cat "/etc/limit/shadowsocks/${user}")
            [[ ${#plus2} -gt 0 ]] && downlink=$(( ${downlink:-0} + plus2 ))
        fi
        echo "${downlink:-0}" > "/etc/limit/shadowsocks/${user}"
        xray api stats --server=127.0.0.1:10000 -name "user>>>${user}>>>traffic>>>downlink" -reset > /dev/null 2>&1
    done

    dirty=0
    for user in "${data[@]}"; do
        [ -e "/etc/shadowsocks/${user}" ] || continue
        checkLimit=$(cat "/etc/shadowsocks/${user}")
        [[ ${#checkLimit} -gt 1 ]] || continue
        [ -e "/etc/limit/shadowsocks/${user}" ] || continue
        Usage=$(cat "/etc/limit/shadowsocks/${user}")
        if [[ ${Usage} -gt ${checkLimit} ]]; then
            exp=$(grep '^#!#' /etc/shadowsocks/.shadowsocks.db | grep -w "$user" | awk '{print $3}' | head -n1)
            sed -i "/^#!# $user $exp/,/^},{/d" /etc/xray/config.json
            sed -i "/^#!# $user $exp/d" /etc/shadowsocks/.shadowsocks.db
            bol=$(cat "/etc/limit/shadowsocks/${user}")
            total=$(con "$bol")
            send-log
            rm -f "/etc/shadowsocks/$user" "/etc/limit/shadowsocks/$user" \
                  "/etc/funny/limit/shadowsocks/ip/${user}" \
                  "/etc/limit/shadowsocks/quota/$user" \
                  "/var/www/html/sodosokws-$user.txt"
            dirty=1
        fi
    done

    if [[ $dirty -eq 1 ]]; then
        systemctl restart xray >/dev/null 2>&1
    fi
done
