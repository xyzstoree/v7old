#!/bin/bash
# limit-ip — daemon pembatas multi-IP
# FIX #5: tiap mode diubah jadi while-true (sebelumnya 1× lalu exit, di-restart
#         systemd → log access.log dipotong setiap restart → log buat deteksi
#         multi-IP justru hilang sebelum sempat dianalisa).
# FIX #21: variable $jum2 yang baca /tmp/ipvmess.txt tidak pernah ada,
#         dihilangkan agar tidak misleading.

send_log() {
    CHATID=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 3)
    KEY=$(grep -E "^#bot# " "/etc/bot/.bot.db" | cut -d ' ' -f 2)
    [ -z "$CHATID" ] || [ -z "$KEY" ] && return 0
    TIME="10"
    URL="https://api.telegram.org/bot$KEY/sendMessage"
    TEXT="
<code>────────────────────</code>
<b>⚠️ NOTIFICATIONS MULTI LOGIN ⚠️</b>
<code>────────────────────</code>
<code>Username  : </code><code>$user</code>
<code>Limit Ip  : </code><code>$data_iplimit</code>
<code>────────────────────</code>
"
    curl -s --max-time $TIME -d "chat_id=$CHATID&disable_web_page_preview=1&text=$TEXT&parse_mode=html" "$URL" >/dev/null
}

vmip() {
    while true; do
        : > /var/log/xray/access.log
        sleep 440
        data=( $(ls /etc/kyt/limit/vmess/ip 2>/dev/null) )
        for user in "${data[@]}"; do
            data_iplimit=$(cat "/etc/kyt/limit/vmess/ip/$user")
            ehh=$(grep "$user" /var/log/xray/access.log \
                | cut -d ' ' -f 3 | sed 's/tcp://g' | cut -d ':' -f 1 \
                | sort -u)
            cekcek=$(printf '%s\n' "$ehh" | grep -c .)
            if [[ $cekcek -gt $data_iplimit ]]; then
                exp=$(grep -w "^### $user" "/etc/xray/config.json" | cut -d ' ' -f 3 | sort -u)
                sed -i "/^### $user $exp/,/^},{/d" /etc/xray/config.json
                sed -i "/^### $user $exp/d" /etc/vmess/.vmess.db
                systemctl restart xray >/dev/null 2>&1
                rm -rf "/etc/kyt/limit/vmess/ip/$user"
                send_log
            fi
            sleep 0.1
        done
    done
}

