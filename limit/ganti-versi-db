#!/bin/bash
# ganti-versi-db — install Dropbear dari source code
# FIX #51: hapus mix apt+yum yang cacat
# FIX #52: tidak generate ulang SEMUA host key (cuma jika file tidak ada)

set -e
RED='\033[1;91m'; GREEN='\033[1;92m'; YELLOW='\033[1;93m'; NC='\033[0m'
DROPBEAR_VERSION="${DROPBEAR_VERSION:-2019.78}"
DROPBEAR_BIN="/usr/sbin/dropbear"

if [[ $EUID -ne 0 ]]; then
    echo -e "${RED}Jalankan sebagai root!${NC}"
    exit 1
fi

clear
echo -e "${GREEN}=== INSTALL DROPBEAR ${DROPBEAR_VERSION} ===${NC}"

systemctl stop dropbear 2>/dev/null || true
[ -f "$DROPBEAR_BIN" ] && cp "$DROPBEAR_BIN" /usr/sbin/dropbear.bak

# FIX #51: hanya satu package manager yang dipakai
if command -v apt-get >/dev/null 2>&1; then
    apt-get update -y
    apt-get install -y --no-install-recommends build-essential zlib1g-dev wget tar bzip2
elif command -v yum >/dev/null 2>&1; then
    yum groupinstall -y "Development Tools"
    yum install -y zlib-devel wget tar bzip2
else
    echo -e "${RED}Tidak ada apt-get/yum. Tidak bisa install dependency.${NC}"
    exit 1
fi

cd /tmp || exit 1
echo -e "${YELLOW}Download Dropbear ${DROPBEAR_VERSION}...${NC}"
wget -q "https://raw.githubusercontent.com/arivpnstores/dropbear/main/dropbear-${DROPBEAR_VERSION}.tar.bz2" \
    -O "dropbear-${DROPBEAR_VERSION}.tar.bz2"

if [ ! -s "dropbear-${DROPBEAR_VERSION}.tar.bz2" ]; then
    echo -e "${RED}Download gagal!${NC}"
    exit 1
fi

tar -xjf "dropbear-${DROPBEAR_VERSION}.tar.bz2"
cd "dropbear-${DROPBEAR_VERSION}" || exit 1

echo -e "${YELLOW}Compile...${NC}"
./configure --prefix=/usr
make -j"$(nproc)"
make install

# Copy binary ke /usr/sbin (tradisional)
[ -x /usr/bin/dropbear ] && cp -f /usr/bin/dropbear /usr/sbin/dropbear

mkdir -p /etc/dropbear

# FIX #52: generate host-key HANYA jika belum ada (jangan invalidate fingerprint user!)
[ -f /etc/dropbear/dropbear_rsa_host_key ]   || dropbearkey -t rsa   -f /etc/dropbear/dropbear_rsa_host_key
[ -f /etc/dropbear/dropbear_ecdsa_host_key ] || dropbearkey -t ecdsa -f /etc/dropbear/dropbear_ecdsa_host_key
[ -f /etc/dropbear/dropbear_ed25519_host_key ] || dropbearkey -t ed25519 -f /etc/dropbear/dropbear_ed25519_host_key 2>/dev/null || true
chmod 600 /etc/dropbear/*_host_key

systemctl start dropbear 2>/dev/null || true

echo -e "${GREEN}CEK VERSI:${NC}"
dropbear -V || true

cd /tmp
rm -rf "dropbear-${DROPBEAR_VERSION}" "dropbear-${DROPBEAR_VERSION}.tar.bz2"
echo -e "${GREEN}SELESAI - Dropbear ${DROPBEAR_VERSION} terinstall${NC}"
